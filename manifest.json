{
  "manifest_version": 3,
  "name": "Return YouTube Dislike",
  "version": "1.4",
  "description": "Restores the dislike count on YouTube videos using the Return YouTube Dislike API.",
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "return-youtube-dislike@placeholder.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}