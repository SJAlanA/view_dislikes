{
  "manifest_version": 3,
  "name": "Return YouTube Dislike",
  "version": "1.1",
  "description": "Restores the dislike count on YouTube videos using the Return YouTube Dislike API.",
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://returnyoutubedislikeapi.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}